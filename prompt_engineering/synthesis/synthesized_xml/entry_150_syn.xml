<?xml version="1.0"?>
<root BTCPP_format="4" main_tree_to_execute="MainTree">
    <BehaviorTree ID="MainTree">
        <Fallback name="EngageOrRandomMove">
            <SequenceStar name="Main">
                <GetTarget target="{target}"/>
                <Move target="{target}"/>
                <Sequence name="AttackIfAdjacent">
                    <TargetAdjacent target="{target}" rule="{rule}"/>
                    <AttackTarget target="{target}"/>
                </Sequence>
            </SequenceStar>
            <RandomMove/>
        </Fallback>
    </BehaviorTree>
</root>
